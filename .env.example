# API Gateway
GATEWAY_PORT=3000
HOST=127.0.0.1
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Service URLs (used by API Gateway for proxying)
AUTH_SERVICE_URL=http://localhost:3001
PROPERTY_SERVICE_URL=http://localhost:3002
OPERATIONS_SERVICE_URL=http://localhost:3003
BOOKING_SERVICE_URL=http://localhost:3004
COMMUNITY_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006

# Remote PostgreSQL
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=rgh_db
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# Service database URLs (all services share the same remote database)
AUTH_PORT=3001
AUTH_DATABASE_URL=postgresql://your-db-user:your-db-password@your-db-host:5432/rgh_db

PROPERTY_PORT=3002
PROPERTY_DATABASE_URL=postgresql://your-db-user:your-db-password@your-db-host:5432/rgh_db

OPERATIONS_PORT=3003
OPERATIONS_DATABASE_URL=postgresql://your-db-user:your-db-password@your-db-host:5432/rgh_db

BOOKING_PORT=3004
BOOKING_DATABASE_URL=postgresql://your-db-user:your-db-password@your-db-host:5432/rgh_db

COMMUNITY_PORT=3005
COMMUNITY_DATABASE_URL=postgresql://your-db-user:your-db-password@your-db-host:5432/rgh_db

NOTIFICATION_PORT=3006
NOTIFICATION_DATABASE_URL=postgresql://your-db-user:your-db-password@your-db-host:5432/rgh_db

# Notification providers (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMS_API_KEY=
PUSH_API_KEY=
